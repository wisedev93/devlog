# =============================================================================
# .env.example
# -----------------------------------------------------------------------------
# 이 파일을 `.env` 로 복사한 뒤 각 값을 채우세요.
#   cp .env.example .env
#
# Vercel 에 배포할 땐 Project Settings → Environment Variables 에
# 동일한 키/값을 등록해야 합니다.
# =============================================================================

# --- Google Analytics 4 -----------------------------------------------------
# https://analytics.google.com 에서 발급받은 측정 ID (G-로 시작)
# 미설정 시 GA 스크립트 자체가 출력되지 않음.
PUBLIC_GA_ID=

# --- giscus (GitHub Discussions 기반 댓글) ----------------------------------
# https://giscus.app 에서 repo 선택 → 카테고리 설정 후 발급되는 값 그대로 입력.
# 4개 값이 전부 채워져야 댓글 위젯이 렌더링됨.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# --- Google Search Console (선택) -------------------------------------------
# Search Console 도메인 소유권 확인 시 meta 태그 방식을 쓸 경우에만 사용.
# DNS TXT 방식으로 확인하면 이 값은 비워둬도 됨.
PUBLIC_GOOGLE_SITE_VERIFICATION=
