---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
---

<div class="flex flex-wrap items-center gap-2">
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="group rounded-full border border-border bg-background-elevated p-2 text-foreground-muted backdrop-blur-md transition-all hover:border-accent hover:text-accent hover:shadow-[0_0_16px_var(--accent-glow)]"
        title={social.linkTitle}
      >
        <social.icon class="inline-block size-5 fill-transparent stroke-current stroke-2" />
        <span class="sr-only">{social.linkTitle}</span>
      </LinkButton>
    ))
  }
</div>
