---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

/**
 * BackButton — 모든 상세 페이지(PostDetails / LabLayout 등)가 공유한다.
 *
 * 동작:
 *  - history 가 있으면 history.back() 으로 직전 페이지로 (브라우저 뒤로가기와 동일).
 *    View Transitions SPA 흐름도 정확히 추적된다.
 *  - history 가 없을 때(새 탭, 직접 진입 등)는 a 태그 기본 동작(fallback URL)으로.
 */
interface Props {
  /** 새 탭/외부 referrer 진입 시 BackButton 이 가리킬 fallback URL. */
  fallback?: string;
}

const { fallback = "/" } = Astro.props;
---

{
  SITE.showBackButton && (
    <div class="app-layout flex items-center justify-start">
      <LinkButton
        id="back-button"
        href={fallback}
        class="focus-outline -ms-2 mt-8 mb-2 hover:text-foreground/75"
      >
        <IconChevronLeft class="inline-block size-6 rtl:rotate-180" />
        <span>Go back</span>
      </LinkButton>
    </div>
  )
}

<script>
  function initBackButton() {
    const backButton: HTMLAnchorElement | null =
      document.querySelector("#back-button");
    if (!backButton || backButton.dataset.backBound === "true") return;

    backButton.dataset.backBound = "true";
    backButton.addEventListener("click", e => {
      if (history.length > 1) {
        e.preventDefault();
        history.back();
      }
      // history 없으면 a 태그 기본 동작(href fallback).
    });
  }

  document.addEventListener("astro:page-load", initBackButton);
  initBackButton();
</script>
