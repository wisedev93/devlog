---
/**
 * /labs/silent-form-validation — silent failure 시연 페이지.
 * 메타데이터는 src/data/labsMeta.ts 에서, island 는 src/islands/SilentFailureLab.tsx 에서.
 */
import LabLayout from "@/layouts/LabLayout.astro";
import SilentFailureLab from "@/islands/SilentFailureLab";
import { getLab } from "@/data/labsMeta";
const lab = getLab("silent-form-validation");
if (!lab) {
  return Astro.redirect("/labs");
}
---

<LabLayout
  title={lab.title}
  summary={lab.summary}
  tags={lab.tags}
  post={lab.post}
  pubDate={lab.pubDate}
>
  <SilentFailureLab client:visible />
</LabLayout>
