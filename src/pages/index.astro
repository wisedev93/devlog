---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import FeaturedCard from "@/components/FeaturedCard.astro";
import HeroTerminal from "@/components/HeroTerminal.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// 최상단 와이드 카드용: 첫 Featured 하나를 추출, 나머지는 일반 리스트에 붙임
const [topFeatured, ...restFeatured] = featuredPosts;
const gridPosts = [...restFeatured, ...recentPosts].slice(0, SITE.postPerIndex);

// TODO[PLACEHOLDER]: "What I write about" 카드에 쓸 주제. 자유롭게 편집.
const topics = [
  {
    label: "Frontend",
    desc: "React · TypeScript",
    icon: "⚛",
  },
  {
    label: "Performance",
    desc: "번들·렌더링·Core Web Vitals",
    icon: "⚡",
  },
  {
    label: "기타",
    desc: "등등",
    icon: "◎",
  },
  {
    label: "이모티콘",
    desc: "😇",
    icon: "😆",
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    {/* ========== HERO ========== */}
    <section
      id="hero"
      class="grid items-center gap-10 pt-14 pb-12 sm:pt-20 sm:pb-16 xl:grid-cols-[1.1fr_1fr] xl:gap-12"
    >
      <div>
        <div
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-background-elevated px-3 py-1 text-xs text-foreground-muted backdrop-blur-md"
        >
          <span
            class="size-1.5 rounded-full bg-accent shadow-[0_0_8px_var(--accent-glow)]"
          ></span>
          {SITE.author} · Frontend Engineer
        </div>

        <h1
          class="my-2 text-alpine pb-1 text-5xl leading-[1.15] font-bold tracking-tight sm:my-4 sm:text-6xl"
        >
          {SITE.title}
        </h1>

        <p class="mt-6 max-w-xl text-lg text-foreground-muted sm:text-xl">
          {SITE.desc}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/posts/"
            class="group inline-flex items-center gap-1.5 rounded-full bg-accent px-5 py-2 text-sm font-semibold text-background transition-all hover:shadow-[0_0_24px_var(--accent-glow)]"
          >
            Read posts
            <IconArrowRight
              class="inline-block size-4 transition-transform group-hover:translate-x-0.5 rtl:-rotate-180"
            />
          </a>
          <a
            href="/about/"
            class="inline-flex items-center rounded-full border border-border bg-background-elevated px-5 py-2 text-sm font-medium text-foreground backdrop-blur-md transition-colors hover:border-accent hover:text-accent"
          >
            About
          </a>
          <a
            target="_blank"
            href="/rss.xml"
            class="inline-flex items-center rounded-full border border-border bg-background-elevated p-2 text-foreground-muted backdrop-blur-md transition-colors hover:border-accent hover:text-accent"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss width={16} height={16} class="rtl:-rotate-90" />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>

        {
          SOCIALS.length > 0 && (
            <div class="mt-8 flex items-center gap-2">
              <span class="mr-1 text-xs tracking-wider text-foreground-muted uppercase">
                Find me
              </span>
              <Socials />
            </div>
          )
        }
      </div>

      {/* xl 이상에서만 노출되는 터미널 목업 */}
      <div class="hidden xl:block">
        <HeroTerminal />
      </div>
    </section>

    {/* ========== POSTS: 상단 와이드 Featured + 아래 2컬럼 ========== */}
    {
      (topFeatured || gridPosts.length > 0) && (
        <section id="posts" class="border-t border-border pt-12 pb-6">
          <div class="mb-6 flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent shadow-[0_0_8px_var(--accent-glow)]" />
            <h2 class="text-xs font-semibold tracking-[0.2em] text-foreground-muted uppercase">
              Latest writing
            </h2>
          </div>

          {topFeatured && <FeaturedCard {...topFeatured} />}

          {gridPosts.length > 0 && (
            <ul class="mt-2 grid gap-4 sm:grid-cols-2 sm:gap-5">
              {gridPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          )}
        </section>
      )
    }

    {/* ========== WHAT I WRITE ABOUT ========== */}
    <section id="topics" class="border-t border-border pt-12 pb-6">
      <div class="mb-6 flex items-center gap-2">
        <span
          class="size-1.5 rounded-full bg-accent shadow-[0_0_8px_var(--accent-glow)]"
        ></span>
        <h2
          class="text-xs font-semibold tracking-[0.2em] text-foreground-muted uppercase"
        >
          What I write about
        </h2>
      </div>
      <ul class="grid gap-4 sm:grid-cols-3">
        {
          topics.map(t => (
            <li class="group rounded-2xl border border-border bg-background-elevated p-5 backdrop-blur-md transition-all hover:-translate-y-0.5 hover:border-accent/60 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)]">
              <div class="mb-2 inline-flex size-9 items-center justify-center rounded-lg border border-border bg-background/40 text-lg text-accent">
                {t.icon}
              </div>
              <h3 class="font-semibold text-foreground transition-colors group-hover:text-accent">
                {t.label}
              </h3>
              <p class="mt-1 text-sm text-foreground-muted">{t.desc}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <div class="my-12 text-center">
      <LinkButton
        href="/posts/"
        class="inline-flex items-center gap-1.5 rounded-full border border-border bg-background-elevated px-5 py-2 text-sm font-medium text-foreground backdrop-blur-md transition-colors hover:border-accent hover:text-accent"
      >
        All Posts
        <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
